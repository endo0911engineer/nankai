{
  "expo": {
    "name": "あと何回",
    "slug": "nankai-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "nankai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF8F3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nankai.app",
      "infoPlist": {
        "CFBundleDisplayName": "あと何回",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF8F3"
      },
      "package": "com.nankai.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "思い出の写真を保存するために、写真へのアクセスを許可してください。",
          "cameraPermission": "大切な人との思い出を撮影するために、カメラへのアクセスを許可してください。撮影した写真はアプリ内の思い出として保存されます。"
        }
      ],
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "思い出のカードを保存するために、写真へのアクセスを許可してください。"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1772f2f8-aff8-4cf9-a945-d072c353ae0a"
      }
    }
  }
}
